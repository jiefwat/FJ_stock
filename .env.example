APP_ID=stock-ts
APP_ENV=local
LOG_LEVEL=INFO
HOST=127.0.0.1
PORT=8501
STOCK_TS_PUBLIC_READONLY=0
STOCK_TS_PROVIDER=auto
# Optional: Tushare token for future provider extension. Do not commit real values.
TUSHARE_TOKEN=
# Optional: iTick API key for quote/K-line fallback enrichment. Do not commit real values.
ITICK_API_KEY=
STOCK_TS_HOLDINGS_PATH=data/portfolio/holdings.csv
STOCK_TS_CACHE_DIR=data/cache

# Optional account protection. Enable for personal writable sites or future sharing.
# Do not commit real passwords/secrets.
STOCK_TS_AUTH_ENABLED=0
STOCK_TS_ADMIN_USERNAME=
STOCK_TS_ADMIN_PASSWORD=
STOCK_TS_SESSION_SECRET=
STOCK_TS_AUTH_DB_PATH=data/auth/users.sqlite3
STOCK_TS_SESSION_TTL_SECONDS=604800
# Set to 1 only when you want visitors to self-register and immediately access the site.
STOCK_TS_ALLOW_REGISTRATION=0

# Optional delivery channels. Keep real secrets in local .env only.
EMAIL_SENDER=
EMAIL_SENDER_NAME=Jiewat Kaka FJ 股票分析助手
EMAIL_PASSWORD=
EMAIL_RECEIVERS=
WECHAT_WEBHOOK_URL=
FEISHU_WEBHOOK_URL=
WECHAT_MSG_TYPE=markdown
WECHAT_MAX_BYTES=4000
NOTIFICATION_REPORT_CHANNELS=email,wechat
NOTIFICATION_REPORT_STYLE=auto

# Optional LLM enhancement. Do not commit real API keys.
# Qwen/DashScope OpenAI-compatible defaults:
STOCK_TS_LLM_PROVIDER=openai-compatible
STOCK_TS_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
STOCK_TS_LLM_MODEL=qwen-plus
STOCK_TS_LLM_API_KEY=
# Or use DASHSCOPE_API_KEY= in local .env.
STOCK_TS_LLM_TEMPERATURE=0.2
STOCK_TS_LLM_TIMEOUT=30
